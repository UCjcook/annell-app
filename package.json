{
  "name": "order-urgency-app",
  "version": "0.1.0",
  "description": "Windows-first order urgency board for Shopify and Etsy sellers",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "vite build"
  },
  "keywords": [
    "electron",
    "shopify",
    "etsy",
    "orders"
  ],
  "author": "Josh + Wheatley",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron": "^37.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "vite": "^7.1.7",
    "wait-on": "^8.0.5"
  }
}
